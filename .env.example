PORT=3000
NODE_ENV=development
NOTION_API_KEY=your_notion_api_key_here
NOTION_ORDERS_DATABASE_ID=your_notion_database_id_here
NOTION_CONTACT_DATABASE_ID=your_notion_contact_database_id_here
NOTION_INVENTORY_DATABASE_ID=your_notion_inventory_database_id_here
NOTION_SHOP_ORDERS_DATABASE_ID=your_notion_shop_orders_database_id_here
# The "📅 Production Schedule" database. A scheduled reconciliation writes one
# per-stage milestone row here for each order that has a "Due Date" set. Share the
# Notion integration with this database, and add a "Stage" (select) + "Order"
# (relation -> Order Tracking Pipeline) property to it (see CLAUDE.md).
NOTION_PRODUCTION_SCHEDULE_DATABASE_ID=your_notion_production_schedule_database_id_here

# Bearer token guarding the milestone-reconciliation cron endpoint
# (GET /api/cron/generate-milestones). On Vercel, set this and Vercel Cron sends
# it automatically as "Authorization: Bearer $CRON_SECRET". Locally, pass the same
# header when calling the endpoint by hand. Unset ⇒ the endpoint returns 401.
CRON_SECRET=your_cron_secret_here

# Optional: the "Client CRM" database. When set, each new custom order upserts a
# client record here (deduped by email) and links the order to it. Unset ⇒ CRM
# linking is skipped and orders behave exactly as before.
NOTION_CLIENT_CRM_DATABASE_ID=your_notion_client_crm_database_id_here

# Resend — customer notification emails (order confirmation, contact
# acknowledgement, back-in-stock request confirmation). RESEND_FROM_EMAIL must
# use a domain verified in the Resend dashboard, e.g. "A.A Atelier <orders@yourdomain>".
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=A.A Atelier <orders@yourdomain>

# Optional: the atelier's own inbox. When set, each new order / contact message /
# back-in-stock request also sends an internal notification here (Reply-To the
# customer), so the team gets an email nudge in addition to the Notion row.
# Leave unset to skip these internal notifications.
ATELIER_INBOX_EMAIL=orders@yourdomain

# Optional: per-function overrides for contact-form mail. Order/shop/back-in-stock
# mail uses RESEND_FROM_EMAIL + ATELIER_INBOX_EMAIL above; contact-form mail uses
# these when set, else falls back to those base vars. Set them to send/receive
# contact mail from a separate address (e.g. hello@) — same verified domain, no
# extra Resend setup.
RESEND_CONTACT_FROM_EMAIL=A.A Atelier <hello@yourdomain>
ATELIER_CONTACT_INBOX_EMAIL=hello@yourdomain

# Stripe (shop checkout). Use test-mode keys locally.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# From `stripe listen` locally, or the webhook endpoint's signing secret on Vercel.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
# The site origin Stripe redirects back to after checkout (the Vite dev server locally).
PUBLIC_BASE_URL=http://localhost:5173
# Optional: comma-separated Stripe Shipping Rate ids (shr_...) to offer at shop
# checkout (create + price them under Shipping → Shipping rates in the Stripe
# Dashboard). Unset = no shipping charged, so shipping simply won't appear at
# checkout until this is set. Two gotchas: the ids must be created in the SAME
# mode as STRIPE_SECRET_KEY (a test-mode shr_ won't work with a live key, and
# vice-versa), and the rate's currency must be USD to match the session. Use
# your test-mode ids here; on Vercel, Production gets your live ids and
# Preview/Development get the test ids (see the deployment note in CLAUDE.md).
STRIPE_SHIPPING_RATE_IDS=

# Optional. The Stage at (and after) which a customer can no longer request a
# measurement change because the garment is in production. Defaults to
# "Cutting/Pinning". Set this if that Stage is named differently in Notion.
# MEASUREMENT_LOCK_FROM_STAGE=Cutting/Pinning
