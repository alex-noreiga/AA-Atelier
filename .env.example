PORT=3000
NODE_ENV=development
NOTION_API_KEY=your_notion_api_key_here
NOTION_ORDERS_DATABASE_ID=your_notion_database_id_here
NOTION_CONTACT_DATABASE_ID=your_notion_contact_database_id_here
NOTION_INVENTORY_DATABASE_ID=your_notion_inventory_database_id_here
NOTION_SHOP_ORDERS_DATABASE_ID=your_notion_shop_orders_database_id_here
# Optional: the "Product Categories" database — the data-driven source for which
# shop categories show the size guide. Each row is a category (its "Name" matches
# an inventory "Item Type" value) with a "Show size guide" checkbox. Share the
# Notion integration with it. Unset ⇒ the shop falls back to a built-in sized-
# category list, so behaviour is unchanged until you populate + enable this.
NOTION_PRODUCT_CATEGORIES_DATABASE_ID=your_notion_product_categories_database_id_here
# The "📅 Production Schedule" database. A scheduled reconciliation writes one
# per-stage milestone row here for each order that has a "Due Date" set. Share the
# Notion integration with this database, and add a "Stage" (select) + "Order"
# (relation -> Order Tracking Pipeline) property to it (see CLAUDE.md).
NOTION_PRODUCTION_SCHEDULE_DATABASE_ID=your_notion_production_schedule_database_id_here

# ****** guarding the milestone-reconciliation cron endpoint
# (GET /api/cron/generate-milestones). On Vercel, set this and Vercel Cron sends
# it automatically as "Authorization: ******". Locally, pass the same
# header when calling the endpoint by hand. Unset ⇒ the endpoint returns 401.
CRON_SECRET=your_cron_secret_here


# Optional: the "Client CRM" database. When set, each new custom order upserts a
# client record here (deduped by email) and links the order to it. Unset ⇒ CRM
# linking is skipped and orders behave exactly as before.
NOTION_CLIENT_CRM_DATABASE_ID=your_notion_client_crm_database_id_here

# Custom-order payments. The order's "invoices & payments" record is the source
# of truth for all three staged payments — first deposit, second deposit, and the
# final balance (itemized materials + labor from "Invoice Line Items", minus the
# deposits paid). The app READS both databases and collects each stage via Stripe.
# Share the Notion integration with BOTH databases or reads 404. Deposits are
# payable once the atelier sets their amount; the itemized balance appears once
# the atelier ticks "Invoice Ready" on the invoice.
NOTION_INVOICES_DATABASE_ID=your_notion_invoices_database_id_here
NOTION_INVOICE_LINE_ITEMS_DATABASE_ID=your_notion_invoice_line_items_database_id_here

# Appointment scheduling runs on Google Calendar (not Notion). Availability is
# each staff member's calendar free/busy; each booking is written as a calendar
# event that invites the customer (and creates a Google Meet link for virtual).
#
# GOOGLE_SERVICE_ACCOUNT_KEY: the full JSON of a Google Cloud service-account
# key (enable the Google Calendar API AND the Google Sheets API). For it to act
# as each staff member — read free/busy, write events, invite the customer —
# authorize its client id for scope https://www.googleapis.com/auth/calendar
# under Google Workspace Admin → Security → API controls → Domain-wide
# delegation. Paste the JSON on one line (Vercel accepts multi-line too).
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}

# APPOINTMENT_SHEET_ID: the id of a Google Sheet holding the staff working hours
# — the "when are we open" grid Google free/busy can't provide. The atelier edits
# it live (no redeploy). Columns, in order, with a header row 1 (data from row 2):
#   A Staff | B Email | C Day | D Start | E End | F Locations
# e.g.  Alexandra | alexandra@a3iceanddance.com | Mon-Fri | 10:00 | 17:00 | in-person, virtual
# `Staff` must match the names in lib/appointments/catalog.ts; `Email` is each
# person's Workspace calendar; `Day` accepts Mon/Monday, comma lists, and ranges
# (Mon-Fri); `Locations` is comma-separated in-person / virtual. Share the sheet
# with the service-account email (Viewer) — no domain-wide delegation needed for
# Sheets. The id is the long token in the sheet URL (…/spreadsheets/d/<ID>/edit).
APPOINTMENT_SHEET_ID=your_google_sheet_id_here
# Optional: override the range read (default "A2:F", i.e. the first tab).
# APPOINTMENT_SHEET_RANGE=Schedule!A2:F

# Resend — customer notification emails (order confirmation, contact
# acknowledgement, back-in-stock request confirmation). RESEND_FROM_EMAIL must
# use a domain verified in the Resend dashboard, e.g. "A.A Atelier <orders@a3iceanddance.com>".
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=A.A Atelier <orders@a3iceanddance.com>

# Optional: the atelier's own inbox. When set, each new order / contact message /
# back-in-stock request also sends an internal notification here (Reply-To the
# customer), so the team gets an email nudge in addition to the Notion row.
# Leave unset to skip these internal notifications.
ATELIER_INBOX_EMAIL=orders@a3iceanddance.com

# Optional: per-function overrides for contact-form mail. Order/shop/back-in-stock
# mail uses RESEND_FROM_EMAIL + ATELIER_INBOX_EMAIL above; contact-form mail uses
# these when set, else falls back to those base vars. Set them to send/receive
# contact mail from a separate address (e.g. hello@) — same verified domain, no
# extra Resend setup.
RESEND_CONTACT_FROM_EMAIL=A.A Atelier <hello@a3iceanddance.com>
ATELIER_CONTACT_INBOX_EMAIL=hello@a3iceanddance.com

# Optional: per-function overrides for appointment-booking mail. Falls back to
# the base RESEND_FROM_EMAIL / ATELIER_INBOX_EMAIL when unset.
RESEND_APPOINTMENTS_FROM_EMAIL=A.A Atelier <appointments@a3iceanddance.com>
ATELIER_APPOINTMENTS_INBOX_EMAIL=appointments@a3iceanddance.com

# Appointment booking policy (all optional — sensible defaults shown).
# APPOINTMENT_TIMEZONE is the IANA zone the atelier's working hours and offered
# slot times are expressed in. Lead/advance bound how soon and how far out a
# customer can book; the step is the grid slots snap to within working hours.
APPOINTMENT_TIMEZONE=America/Chicago
APPOINTMENT_MIN_LEAD_HOURS=24
APPOINTMENT_MAX_ADVANCE_DAYS=45
APPOINTMENT_SLOT_STEP_MINUTES=15

# Stripe (shop checkout). Use test-mode keys locally.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# From `stripe listen` locally, or the webhook endpoint's signing secret on Vercel.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
# The site origin Stripe redirects back to after checkout (the Vite dev server locally).
PUBLIC_BASE_URL=http://localhost:5173
# Optional: comma-separated Stripe Shipping Rate ids (shr_...) to offer at shop
# checkout (create + price them under Shipping → Shipping rates in the Stripe
# Dashboard). Unset = no shipping charged, so shipping simply won't appear at
# checkout until this is set. Two gotchas: the ids must be created in the SAME
# mode as STRIPE_SECRET_KEY (a test-mode shr_ won't work with a live key, and
# vice-versa), and the rate's currency must be USD to match the session. Use
# your test-mode ids here; on Vercel, Production gets your live ids and
# Preview/Development get the test ids (see the deployment note in CLAUDE.md).
STRIPE_SHIPPING_RATE_IDS=

# Optional. The Stage at (and after) which a customer can no longer request a
# measurement change because the garment is in production. Defaults to
# "Cutting/Pinning". Set this if that Stage is named differently in Notion.
# MEASUREMENT_LOCK_FROM_STAGE=Cutting/Pinning
