{
  // Type-checks the test suite. Kept separate from `tsconfig.json` so tests
  // stay out of the build graph while still being covered by `pnpm typecheck`.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": [
      "node",
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  // The base config excludes `**/*.test.ts`; `extends` would inherit that and
  // silently skip the files this config exists to check.
  "exclude": ["node_modules", "build", "dist"],
  "include": ["src/**/*", "test/**/*", "vitest.config.ts"]
}
