{
  // Type-checks the test suite. Kept separate from `tsconfig.json` so tests
  // stay out of the *build* graph (that one has `rootDir: "src"` and emits to
  // `dist/`) while still being covered by `pnpm typecheck`.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node", "vitest/globals"]
  },
  "include": ["test", "src", "vitest.config.ts"]
}
